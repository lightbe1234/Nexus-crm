rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return request.auth != null && getUserData().role == 'Admin';
    }
    function isEmployee() {
      return request.auth != null && getUserData().role == 'Employee';
    }
    function isAuth() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    match /clients/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /projects/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /tasks/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() || isEmployee();
      allow delete: if isAdmin();
    }

    match /invoices/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Employees can now read their own profile document (doc ID == their UID)
    match /employees/{docId} {
      allow read: if isAdmin() || (isAuth() && request.auth.uid == docId);
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /activities/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
    }

    // Attendance: employees manage only their own records; admins manage all
    match /attendance/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Performance: read own or admin; only admin can write (computed server-side or admin panel)
    match /performance/{docId} {
      allow read: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}